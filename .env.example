# Amazon Associates — Tracking IDs por marketplace.
# Usa o ID correspondente a cada programa. O Amazon.es é o principal
# para tráfego PT (envia para Portugal).
PUBLIC_AMAZON_TAG_ES=
PUBLIC_AMAZON_TAG_COM=
PUBLIC_AMAZON_TAG_UK=
PUBLIC_AMAZON_TAG_DE=
PUBLIC_AMAZON_TAG_FR=
PUBLIC_AMAZON_TAG_IT=

# Fallback usado quando não existe tag para o marketplace detetado.
# Nota: para amazon.es existe uma reserva embutida no código (src/lib/afiliados.ts).
PUBLIC_AMAZON_TAG=

# URL canónico do site (sem barra final)
PUBLIC_SITE_URL=https://kindleportugal.com

# Email de contacto público (mostrado no footer e página de contacto)
PUBLIC_CONTACT_EMAIL=ola@kindleportugal.com

# Analytics (opcional — Plausible)
# PUBLIC_PLAUSIBLE_DOMAIN=kindleportugal.com
