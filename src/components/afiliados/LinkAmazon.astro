---
import { urlAfiliado } from '@lib/afiliados';

interface Props {
  /** URL da Amazon (qualquer marketplace suportado) */
  href: string;
  /** Rel extra — default já inclui sponsored nofollow noopener */
  rel?: string;
  /** Target — default _blank */
  target?: string;
  /** Classes CSS extra */
  class?: string;
}

const {
  href,
  rel = 'sponsored nofollow noopener',
  target = '_blank',
  class: classe,
} = Astro.props;

const finalHref = urlAfiliado(href);
---

<a
  href={finalHref}
  rel={rel}
  target={target}
  data-afiliado="amazon"
  class={classe}
>
  <slot />
</a>
