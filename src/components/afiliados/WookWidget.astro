---
import { WOOK_AID, WOOK_BID_BANNER } from '@lib/wook';

/**
 * Cartão de parceria Wook.
 *
 * Usa o logotipo oficial alojado em `public/banners/wook-logo.png`
 * (alojamos localmente porque o `afiliados.wook.pt` tem hotlink
 * protection — pedidos de fora do portal logado dão 403).
 *
 * O cartão é branco em ambas as variantes; a variante `escuro`
 * apenas escurece a sombra e os textos auxiliares à volta para
 * destacar contra fundos dark gradient (hero das listings).
 *
 * O pixel 1×1 da `programadeafiliados.wook.pt` continua a contar
 * impressões — esse não tem proteção.
 */

interface Props {
  /** Identificador do banner (a_bid) para tracking de criativo. */
  bid?: string;
  /** Classes Tailwind extra na secção exterior. */
  classe?: string;
  /** Carregar pixel com prioridade quando o banner aparece acima do fold. */
  prioridade?: boolean;
  /** Variante de cor — útil para ajustar contra fundos claros vs escuros. */
  variante?: 'claro' | 'escuro';
}

const {
  bid = WOOK_BID_BANNER,
  classe = '',
  prioridade = false,
  variante = 'claro',
} = Astro.props;

const linkUrl = `https://www.wook.pt/?a_aid=${WOOK_AID}&a_bid=${bid}`;
const pixelUrl = `https://programadeafiliados.wook.pt/scripts/qgm99l1ix25?a_aid=${WOOK_AID}&a_bid=${bid}`;

const fundoCartao =
  variante === 'escuro'
    ? 'border-white/15 bg-white/95 text-marinho-900'
    : 'border-marinho-200 bg-white text-marinho-900';
---

<aside class:list={['relative', classe]} aria-label="Parceria Wook" data-afiliado="wook">
  <a
    href={linkUrl}
    rel="sponsored nofollow noopener"
    target="_blank"
    class:list={[
      'group block rounded-2xl border px-6 py-6 text-center transition-all hover:-translate-y-0.5',
      fundoCartao,
    ]}
    style="box-shadow: var(--shadow-media);"
  >
    <span class="inline-block rounded-full bg-marinho-50 px-2.5 py-0.5 text-[0.625rem] font-bold uppercase tracking-[0.12em] text-marinho-500">
      Parceria Wook
    </span>

    <img
      src="/banners/wook-logo.png"
      alt="wook"
      width="600"
      height="226"
      loading={prioridade ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={prioridade ? 'high' : 'auto'}
      class="mx-auto mt-4 block h-auto w-full max-w-[180px]"
    />

    <p class="mt-3 text-xs font-medium uppercase tracking-wider text-marinho-500">
      Livros em português europeu
    </p>

    <p class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-marca-600 transition-colors group-hover:text-marca-700">
      Ver na livraria
      <span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
    </p>
  </a>

  <p
    class:list={[
      'mt-2 text-center text-[0.6875rem]',
      variante === 'escuro' ? 'text-creme-100/60' : 'text-marinho-400',
    ]}
  >
    Conteúdo afiliado ·{' '}
    <a
      href="/divulgacao-afiliados"
      class:list={[
        'underline decoration-marca-400 underline-offset-2 hover:text-marca-600',
        variante === 'escuro' ? 'text-creme-100/80' : 'text-marinho-500',
      ]}
    >divulgação</a>
  </p>

  {/* Pixel 1×1 — Wook tracking; fora do viewport para não causar layout-shift */}
  <img
    src={pixelUrl}
    width="1"
    height="1"
    alt=""
    aria-hidden="true"
    loading={prioridade ? 'eager' : 'lazy'}
    style="border:0;position:absolute;left:-9999px;width:1px;height:1px;"
  />
</aside>
