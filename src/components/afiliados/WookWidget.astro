---
import { WOOK_AID, WOOK_BID_MODULO, urlWidgetModulo } from '@lib/wook';

/**
 * Widget Wook (afiliados) — embute o iframe oficial fornecido pela Wook
 * com um cartão editorial à volta, em vez de o pôr como banner solto.
 *
 * Notas:
 * - A JS de auto-resize que vem no embed Wook não funciona (cross-origin
 *   bloqueia o acesso ao DOM do iframe). Usamos altura fixa configurável.
 * - O iframe carrega lazy para não impactar a primeira pintura.
 * - Disclosure de afiliado vem embutida.
 */

interface Props {
  titulo?: string;
  legenda?: string;
  /** Altura do iframe em pixels. Ajustar consoante o widget Wook escolhido. */
  altura?: number;
  /** Identificador de afiliado Wook (a_aid). Por omissão, lê de env / fallback. */
  aid?: string;
  /** Identificador do banner/módulo (a_bid). Por omissão, lê de env / fallback. */
  bid?: string;
  /** Classes Tailwind extra na secção exterior. */
  classe?: string;
}

const {
  titulo = 'Livros em português para o teu Kindle',
  legenda = 'A Wook é a maior livraria online portuguesa, com forte catálogo em PT-PT, incluindo ebooks compatíveis com Kindle via Send to Kindle. Esta é a nossa parceira em Portugal.',
  altura = 460,
  aid = WOOK_AID,
  bid = WOOK_BID_MODULO,
  classe = '',
} = Astro.props;

const widgetUrl = urlWidgetModulo(bid, aid);
---

<section
  class:list={[
    'relative my-12 overflow-hidden rounded-2xl border border-salvia-200 bg-gradient-to-br from-white via-salvia-50 to-creme-50 p-6 sm:p-8',
    classe,
  ]}
  style="box-shadow: var(--shadow-media);"
  aria-label="Sugestões da Wook"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -right-12 -top-12 h-48 w-48 rounded-full opacity-40 blur-3xl"
    style="background: radial-gradient(circle, #8aa593 0%, transparent 70%);"
  />

  <div class="relative">
    <span class="pill pill-salvia">Parceiro PT — Wook</span>
    <h2
      class="mt-2 text-2xl font-bold text-marinho-900 sm:text-3xl"
      style="font-family: var(--font-serif); letter-spacing: -0.02em;"
    >
      {titulo}
    </h2>
    <p class="mt-3 max-w-2xl text-sm text-marinho-600">{legenda}</p>
  </div>

  <div
    class="relative mt-6 overflow-hidden rounded-xl bg-white"
    style="border: 1px solid rgba(15,26,36,0.06);"
  >
    <iframe
      src={widgetUrl}
      title="Sugestões de livros — Wook"
      loading="lazy"
      width="100%"
      height={altura}
      frameborder="0"
      class="block w-full"
      data-afiliado="wook"
      referrerpolicy="no-referrer-when-downgrade"
    />
  </div>

  <p class="relative mt-4 text-xs text-marinho-400">
    Conteúdo da nossa parceira{' '}
    <a
      href="https://www.wook.pt"
      rel="sponsored nofollow noopener"
      target="_blank"
      class="underline decoration-marinho-200 underline-offset-2 hover:text-marinho-700"
    >
      Wook
    </a>
    . Compras feitas a partir do widget podem render comissão sem custo adicional para ti. Ver a{' '}
    <a
      href="/divulgacao-afiliados"
      class="underline decoration-marca-400 underline-offset-2 hover:text-marca-600"
    >
      divulgação
    </a>
    .
  </p>
</section>
