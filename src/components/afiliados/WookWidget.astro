---
import { WOOK_AID } from '@lib/wook';

/**
 * Banner Wook (afiliado) — versão imagem estática, em vez de iframe widget.
 *
 * Usa o banner gráfico oficial servido por afiliados.wook.pt + o pixel
 * de tracking de programadeafiliados.wook.pt. É leve, indexável,
 * sem cross-origin issues.
 *
 * Por defeito mostra o banner "WOOK" 600×226 (a_bid=581bfdfb).
 * Para outros banners do portal Wook, passar `bid`, `imagemUrl`,
 * `largura` e `altura`.
 */

interface Props {
  /** ID do banner Wook (a_bid). */
  bid?: string;
  /** URL absoluto da imagem do banner. Forçar HTTPS para evitar mixed content. */
  imagemUrl?: string;
  /** Largura nativa da imagem em pixels (para o atributo width). */
  largura?: number;
  /** Altura nativa da imagem em pixels (para o atributo height). */
  altura?: number;
  /** Texto alternativo da imagem. */
  alt?: string;
  /** Frase curta de contexto sob o banner (opcional). */
  legenda?: string;
  /** Classes extra na secção exterior. */
  classe?: string;
  /** Carregar com prioridade (sem lazy). Usar quando o banner está acima do fold. */
  prioridade?: boolean;
}

const {
  bid = '581bfdfb',
  imagemUrl = 'https://afiliados.wook.pt/accounts/default1/banners/wook_logo_vF_rgb_2.jpg',
  largura = 600,
  altura = 226,
  alt = 'WOOK — livraria online portuguesa',
  legenda = '',
  classe = '',
  prioridade = false,
} = Astro.props;

const linkUrl = `https://www.wook.pt/?a_aid=${WOOK_AID}&a_bid=${bid}`;
const pixelUrl = `https://programadeafiliados.wook.pt/scripts/qgm99l1ix25?a_aid=${WOOK_AID}&a_bid=${bid}`;
---

<aside
  class:list={['my-6 text-center', classe]}
  aria-label="Banner Wook"
  data-afiliado="wook"
>
  <a
    href={linkUrl}
    rel="sponsored nofollow noopener"
    target="_blank"
    class="inline-block max-w-full align-middle transition-opacity hover:opacity-90"
  >
    <img
      src={imagemUrl}
      alt={alt}
      width={largura}
      height={altura}
      loading={prioridade ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={prioridade ? 'high' : 'auto'}
      class="mx-auto block h-auto max-w-full"
    />
  </a>

  <p class="mt-2 text-xs text-marinho-400">
    <span class="font-medium text-marinho-500">Conteúdo afiliado</span> ·{' '}
    <a
      href="https://www.wook.pt"
      rel="sponsored nofollow noopener"
      target="_blank"
      class="underline decoration-marinho-200 underline-offset-2 hover:text-marinho-700"
    >Wook</a>
    {legenda ? ` · ${legenda}` : ''} ·{' '}
    <a
      href="/divulgacao-afiliados"
      class="underline decoration-marca-400 underline-offset-2 hover:text-marca-600"
    >divulgação</a>
  </p>

  {/* Pixel de tracking 1×1 — mantido fora de viewport para não criar layout-shift */}
  <img
    src={pixelUrl}
    width="1"
    height="1"
    alt=""
    aria-hidden="true"
    loading="lazy"
    style="border:0;position:absolute;left:-9999px;width:1px;height:1px;"
  />
</aside>
