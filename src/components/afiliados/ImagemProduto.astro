---
import { tagPara, urlAfiliado, type Marketplace } from '@lib/afiliados';

interface Props {
  /** ASIN do produto na Amazon (10 caracteres) */
  asin: string;
  /** Marketplace para pedir a imagem (default: es) */
  marketplace?: Marketplace;
  /** Texto alternativo — obrigatório para acessibilidade e SEO */
  alt: string;
  /** Largura em px da imagem servida pela Amazon (250, 500 ou 1000) */
  tamanho?: 250 | 500 | 1000;
  /** Se true, envolve a imagem num link de afiliado para a página do produto */
  linkar?: boolean;
  /** Classes CSS extra para a img */
  classe?: string;
  /** loading strategy */
  loading?: 'lazy' | 'eager';
  /**
   * Formato de apresentação.
   * - 'normal' (default): bloco com ~180-240 px, centrado.
   * - 'pequeno': miniatura ~120 px, adequada a inline dentro de guias longos.
   * - 'destaque': tamanho maior (~320 px) para heros ou primeiras imagens.
   */
  formato?: 'normal' | 'pequeno' | 'destaque';
}

const {
  asin,
  marketplace = 'es',
  alt,
  tamanho,
  linkar = true,
  classe = '',
  loading = 'lazy',
  formato = 'normal',
} = Astro.props;

const tamanhoEfetivo: 250 | 500 | 1000 = tamanho ?? (formato === 'pequeno' ? 250 : 500);

const classesFormato: Record<'normal' | 'pequeno' | 'destaque', string> = {
  normal: 'mx-auto block max-h-52 w-auto my-6',
  pequeno: 'mx-auto block max-h-32 w-auto my-4',
  destaque: 'mx-auto block max-h-80 w-auto my-8',
};

// `mix-blend-mode: multiply` funde o fundo branco das imagens Amazon com
// o fundo da página (creme). Sem isto, aparece um rectângulo branco.
const imgStyle = 'mix-blend-mode: multiply;';

// Amazon Image Widget — ferramenta oficial do programa Associates.
// A Amazon serve a imagem e regista a impressão ligada ao tracking ID.
const marketConfig: Record<
  Marketplace,
  { widget: string; place: string; produtoHost: string }
> = {
  es: { widget: 'ws-eu.amazon-adsystem.com', place: 'ES', produtoHost: 'www.amazon.es' },
  com: { widget: 'ws-na.amazon-adsystem.com', place: 'US', produtoHost: 'www.amazon.com' },
  uk: { widget: 'ws-eu.amazon-adsystem.com', place: 'GB', produtoHost: 'www.amazon.co.uk' },
  de: { widget: 'ws-eu.amazon-adsystem.com', place: 'DE', produtoHost: 'www.amazon.de' },
  fr: { widget: 'ws-eu.amazon-adsystem.com', place: 'FR', produtoHost: 'www.amazon.fr' },
  it: { widget: 'ws-eu.amazon-adsystem.com', place: 'IT', produtoHost: 'www.amazon.it' },
};

const cfg = marketConfig[marketplace];
const tag = tagPara(marketplace);
const semTag = !tag;

// Proxy no nosso domínio — ver functions/api/img.ts. Evita que ad-blockers
// filtrem o host amazon-adsystem.com; o pedido parte do browser para
// kindleportugal.com, e o proxy na edge Cloudflare vai buscar a imagem
// server-side à Amazon. Em dev (npm run dev) o endpoint não existe e cai
// diretamente no fallback, mas em produção (Cloudflare Pages) funciona.
const srcWidget = `/api/img?asin=${asin}&m=${marketplace}&size=${tamanhoEfetivo}`;

// Fallback para quando o proxy não está disponível (dev local) ou o ASIN
// não tem imagem no catálogo Amazon.
const srcFallback = '/placeholder-amazon.svg';

const hrefProduto = urlAfiliado(`https://${cfg.produtoHost}/dp/${asin}`);

const imgClasses = `object-contain ${classesFormato[formato]} ${classe}`.trim();
---

{
  semTag ? (
    <img
      src={srcFallback}
      alt={alt}
      loading={loading}
      decoding="async"
      class={imgClasses}
      style={imgStyle}
      referrerpolicy="no-referrer-when-downgrade"
    />
  ) : linkar ? (
    <a
      href={hrefProduto}
      rel="sponsored nofollow noopener"
      target="_blank"
      data-afiliado="amazon"
      data-mercado={marketplace}
      class="inline-block transition-transform duration-300 hover:-translate-y-0.5"
    >
      <img
        src={srcWidget}
        alt={alt}
        loading={loading}
        decoding="async"
        class={imgClasses}
        style={imgStyle}
        referrerpolicy="no-referrer-when-downgrade"
        onerror={`this.onerror=null;this.src='${srcFallback}'`}
      />
    </a>
  ) : (
    <img
      src={srcWidget}
      alt={alt}
      loading={loading}
      decoding="async"
      class={imgClasses}
      style={imgStyle}
      referrerpolicy="no-referrer-when-downgrade"
      onerror={`this.onerror=null;this.src='${srcFallback}'`}
    />
  )
}
