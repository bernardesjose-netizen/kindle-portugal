---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import DisclosureBanner from '@components/afiliados/DisclosureBanner.astro';
import BotaoAmazon from '@components/afiliados/BotaoAmazon.astro';
import LojasAmazon from '@components/afiliados/LojasAmazon.astro';
import ImagemProduto from '@components/afiliados/ImagemProduto.astro';
import OrnamentoFundo from '@components/ui/OrnamentoFundo.astro';
import FotoFundoDecorativa from '@components/ui/FotoFundoDecorativa.astro';
import { formatarPreco, formatarData } from '@lib/formatters';

interface Props {
  modelo: CollectionEntry<'modelos'>;
}

const { modelo } = Astro.props;
const d = modelo.data;
const e = d.especificacoes;

// Foto decorativa por modelo (Unsplash, gratuitas, hotlink pelo CDN oficial).
// Se um URL falhar, o componente esconde a imagem automaticamente via onerror.
const fotosPorModelo: Record<string, string> = {
  basico: 'https://images.unsplash.com/photo-1524995997946-a1c2e315a42f?w=1600&q=80&auto=format',
  paperwhite: 'https://images.unsplash.com/photo-1507842217343-583bb7270b66?w=1600&q=80&auto=format',
  scribe: 'https://images.unsplash.com/photo-1519682337058-a94d519337bc?w=1600&q=80&auto=format',
  colorsoft: 'https://images.unsplash.com/photo-1481627834876-b7833e8f5570?w=1600&q=80&auto=format',
};
const fotoFundoSrc = fotosPorModelo[modelo.id] ?? fotosPorModelo.paperwhite;

const productLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: d.nome,
  brand: { '@type': 'Brand', name: d.fabricante },
  description: d.descricao_curta,
  ...(d.asin ? { sku: d.asin } : {}),
  ...(d.url_amazon && d.preco_referencia_eur
    ? {
        offers: {
          '@type': 'Offer',
          priceCurrency: 'EUR',
          price: d.preco_referencia_eur,
          url: d.url_amazon,
          availability: 'https://schema.org/InStock',
        },
      }
    : {}),
};
---

<BaseLayout
  titulo={d.nome}
  descricao={d.descricao_curta}
  tipo="article"
  dataPublicacao={d.data_publicacao}
  dataRevisao={d.data_revisao}
  jsonLd={productLd}
  semOrnamento={true}
>
  <article class="relative overflow-hidden py-10 lg:py-14">
    <FotoFundoDecorativa
      src={fotoFundoSrc}
      alt={`Ambiente de leitura com ${d.nome}`}
      opacidade={0.22}
      posicao="fundo"
      altura="32rem"
      desfocagem={false}
    />
    <OrnamentoFundo motivo="e-reader" posicao="topo-direita" intensidade="subtil" tom="marinho" />
    <OrnamentoFundo motivo="livro-aberto" posicao="fundo-esquerda" intensidade="subtil" tom="dourado" />
    <Container largura="normal">
      <header class="mb-12 grid gap-8 md:grid-cols-[1fr_1.1fr] md:items-center">
        <div>
          <span class="pill">
            {d.fabricante} · {d.ano_lancamento}{d.geracao ? ` · ${d.geracao}` : ''}
          </span>
          <h1
            class="mt-3 text-[2rem] font-bold leading-[1.1] text-marinho-900 sm:text-4xl lg:text-5xl"
            style="font-family: var(--font-serif); letter-spacing: -0.03em;"
          >
            {d.nome}
          </h1>
          <p class="mt-4 text-lg text-marinho-600 sm:text-xl">{d.descricao_curta}</p>

          {d.preco_referencia_eur && (
            <p class="mt-6 flex items-baseline gap-2 text-sm">
              <span class="text-marinho-400">a partir de</span>
              <strong
                class="text-2xl text-marinho-900"
                style="font-family: var(--font-serif);"
              >
                {formatarPreco(d.preco_referencia_eur)}
              </strong>
              {d.preco_data && (
                <span class="text-marinho-400">· preço a {formatarData(d.preco_data)}</span>
              )}
            </p>
          )}

          {d.url_amazon && (
            <div class="mt-6">
              <BotaoAmazon url={d.url_amazon} tamanho="grande">
                Ver {d.nome} na Amazon
              </BotaoAmazon>
            </div>
          )}
        </div>

        {d.imagem_hero ? (
          <figure class="aspect-[4/3] overflow-hidden rounded-2xl border border-marinho-100 bg-gradient-to-br from-white to-creme-100" style="box-shadow: var(--shadow-media);">
            <img
              src={d.imagem_hero.src}
              alt={d.imagem_hero_alt ?? `Fotografia do ${d.nome}`}
              width={d.imagem_hero.width}
              height={d.imagem_hero.height}
              class="h-full w-full object-contain"
              loading="eager"
            />
          </figure>
        ) : d.asin ? (
          <figure
            class="flex aspect-[4/3] items-center justify-center overflow-hidden rounded-2xl border border-marinho-100 bg-gradient-to-br from-white to-creme-100 p-6"
            style="box-shadow: var(--shadow-media);"
          >
            <ImagemProduto
              asin={d.asin}
              alt={d.imagem_hero_alt ?? `${d.nome} visto de frente`}
              tamanho={500}
              linkar={false}
              loading="eager"
              classe="max-h-full"
            />
          </figure>
        ) : (
          <div
            class="relative aspect-[4/3] overflow-hidden rounded-2xl border border-marinho-100 bg-gradient-to-br from-marinho-800 to-marinho-900"
            style="box-shadow: var(--shadow-media);"
            aria-hidden="true"
          >
            <div class="absolute inset-0 flex items-center justify-center">
              <svg viewBox="0 0 200 260" class="h-4/5 w-auto">
                <rect x="20" y="10" width="160" height="240" rx="14" fill="#fefbf5" stroke="#f97e07" stroke-width="2" />
                <rect x="40" y="35" width="120" height="2" fill="#4a5568" />
                <rect x="40" y="45" width="120" height="2" fill="#4a5568" />
                <rect x="40" y="55" width="100" height="2" fill="#4a5568" />
                <rect x="40" y="70" width="120" height="2" fill="#4a5568" />
                <rect x="40" y="80" width="110" height="2" fill="#4a5568" />
                <rect x="40" y="90" width="120" height="2" fill="#4a5568" />
                <circle cx="100" cy="215" r="6" fill="#f97e07" />
              </svg>
            </div>
            <div
              class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-marca-400 via-marca-500 to-dourado-400"
            />
          </div>
        )}
      </header>

      <section class="mt-10 grid gap-8 md:grid-cols-3">
        <div class="md:col-span-2 space-y-6">
          {d.destaques.length > 0 && (
            <div>
              <h2 class="text-xl font-semibold text-marinho-900">Destaques</h2>
              <ul class="mt-3 space-y-1.5 text-marinho-600">
                {d.destaques.map((h) => <li>— {h}</li>)}
              </ul>
            </div>
          )}

          <div class="grid gap-5 sm:grid-cols-2">
            {d.pros.length > 0 && (
              <div class="rounded-xl border border-salvia-100 bg-salvia-50 p-5">
                <h3 class="flex items-center gap-2 font-semibold text-salvia-700">
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Pontos fortes
                </h3>
                <ul class="mt-3 space-y-1.5 text-sm text-salvia-700">
                  {d.pros.map((p) => <li class="pl-3 -indent-3">+ {p}</li>)}
                </ul>
              </div>
            )}
            {d.contras.length > 0 && (
              <div class="rounded-xl border border-ambar-100 bg-ambar-50 p-5">
                <h3 class="flex items-center gap-2 font-semibold text-ambar-800">
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                  </svg>
                  A considerar
                </h3>
                <ul class="mt-3 space-y-1.5 text-sm text-ambar-800">
                  {d.contras.map((c) => <li class="pl-3 -indent-3">− {c}</li>)}
                </ul>
              </div>
            )}
          </div>

          <div class="prose-pt max-w-none prose-headings:text-marinho-900 prose-a:text-marca-700 prose-strong:text-marinho-900">
            <slot />
          </div>

          <div class="relative overflow-hidden rounded-2xl border border-dourado-400/40 bg-gradient-to-br from-creme-100 to-creme-50 p-6">
            <div class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-dourado-400/10 blur-2xl" aria-hidden="true" />
            <h2
              class="relative text-xl font-bold text-marinho-900"
              style="font-family: var(--font-serif); letter-spacing: -0.02em;"
            >
              Veredito
            </h2>
            <p class="relative mt-3 text-marinho-700" style="font-family: var(--font-serif); line-height: 1.7;">
              {d.veredito}
            </p>
          </div>
        </div>

        <aside class="md:col-span-1">
          <h2
            class="text-xl font-bold text-marinho-900"
            style="font-family: var(--font-serif); letter-spacing: -0.02em;"
          >
            Especificações
          </h2>
          <dl class="mt-4 divide-y divide-marinho-100 overflow-hidden rounded-xl border border-marinho-100 bg-white text-sm" style="box-shadow: var(--shadow-suave);">
            <div class="flex justify-between px-4 py-2">
              <dt class="text-marinho-400">Ecrã</dt>
              <dd class="text-marinho-800">{e.ecra_polegadas}" · {e.ecra_ppi} ppi{e.ecra_cor ? ' · cor' : ''}</dd>
            </div>
            <div class="flex justify-between px-4 py-2">
              <dt class="text-marinho-400">Memória</dt>
              <dd class="text-marinho-800">{e.memoria_gb} GB</dd>
            </div>
            <div class="flex justify-between px-4 py-2">
              <dt class="text-marinho-400">Peso</dt>
              <dd class="text-marinho-800">{e.peso_g} g</dd>
            </div>
            <div class="flex justify-between px-4 py-2">
              <dt class="text-marinho-400">Resistência à água</dt>
              <dd class="text-marinho-800">{e.resistencia_agua === 'nenhuma' ? 'Não' : e.resistencia_agua}</dd>
            </div>
            <div class="flex justify-between px-4 py-2">
              <dt class="text-marinho-400">Luz frontal</dt>
              <dd class="text-marinho-800">
                {e.luz_frontal ? 'Sim' : 'Não'}
                {e.luz_ajustavel_temperatura ? ' (temperatura ajustável)' : ''}
              </dd>
            </div>
            <div class="flex justify-between px-4 py-2">
              <dt class="text-marinho-400">Carregamento</dt>
              <dd class="text-marinho-800">{e.carregamento}</dd>
            </div>
            {e.bateria_semanas && (
              <div class="flex justify-between px-4 py-2">
                <dt class="text-marinho-400">Autonomia</dt>
                <dd class="text-marinho-800">até {e.bateria_semanas} semanas</dd>
              </div>
            )}
            {e.stylus_incluido && (
              <div class="flex justify-between px-4 py-2">
                <dt class="text-marinho-400">Stylus</dt>
                <dd class="text-marinho-800">Incluído</dd>
              </div>
            )}
          </dl>

          {d.publico_alvo.length > 0 && (
            <div class="mt-6">
              <h3 class="text-sm font-semibold uppercase tracking-wider text-marinho-400">Ideal para</h3>
              <ul class="mt-2 space-y-1 text-sm text-marinho-600">
                {d.publico_alvo.map((p) => <li>— {p}</li>)}
              </ul>
            </div>
          )}
        </aside>
      </section>

      {d.asin && (
        <LojasAmazon
          asin={d.asin}
          pesquisaAlternativa={d.nome}
          titulo={`Onde comprar o ${d.nome}`}
          legenda={`Escolhe a loja Amazon do teu país. Envios para Portugal sem taxas adicionais a partir da Amazon.es (IVA já incluído).`}
        />
      )}

      <DisclosureBanner variante="discreta" />
    </Container>
  </article>
</BaseLayout>
