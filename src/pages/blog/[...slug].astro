---
import { getCollection, render } from 'astro:content';
import ArtigoLayout from '@layouts/ArtigoLayout.astro';

export async function getStaticPaths() {
  const artigos = await getCollection('blog', ({ data }) => !data.rascunho);
  return artigos.map((artigo) => ({
    params: { slug: artigo.id },
    props: { artigo },
  }));
}

// Mapa slug → ASIN do dispositivo a usar como hero image junto ao título.
// Cobre o catálogo Kindle, Kobo e BOOX. Fallback Paperwhite.
const heroPorPost: Record<string, { asin: string; alt: string }> = {
  'kindle-no-amazon-warehouse': {
    asin: 'B0CFPWLGF2',
    alt: 'Kindle Paperwhite, modelo frequente no Amazon Warehouse',
  },
  'loja-oficial-kobo-amazon': {
    asin: 'B0CZXYV8GT',
    alt: 'Kobo Clara BW, agora vendido pela loja oficial Kobo na Amazon',
  },
  'kindle-vs-tablet-melhor-leitura': {
    asin: 'B0CFPWLGF2',
    alt: 'Kindle Paperwhite, o e-reader recomendado para leitura prolongada',
  },
  'kindle-ou-kobo-livros-portugues-comparacao-2026': {
    asin: 'B0CZXYV8GT',
    alt: 'Kobo Clara BW, comparação direta com o Kindle Paperwhite',
  },
  'ebooks-wook-no-kindle-2026': {
    asin: 'B0CFPWLGF2',
    alt: 'Kindle Paperwhite, leitor de referência para ebooks comprados fora da Amazon',
  },
  'boox-wook-2-ebooks-oferta-2026': {
    asin: 'B0F5B6KZ1H',
    alt: 'BOOX Go Color 7, vendido pela Wook com oferta de 2 ebooks',
  },
  'novidades-literatura-portuguesa-kindle-2026': {
    asin: 'B0CP32JG8B',
    alt: 'Kindle básico, porta de entrada para ler em português europeu',
  },
  'amazon-prime-portugal-vale-a-pena': {
    asin: 'B0CFPWLGF2',
    alt: 'Kindle Paperwhite, modelo coberto pelos benefícios Prime',
  },
  'ola-mundo': {
    asin: 'B0CFPWLGF2',
    alt: 'Kindle Paperwhite',
  },
};

const { artigo } = Astro.props;
const { Content } = await render(artigo);
const d = artigo.data;
const hero = heroPorPost[artigo.id];
---

<ArtigoLayout
  titulo={d.titulo}
  descricao={d.descricao}
  autor={d.autor}
  dataPublicacao={d.data_publicacao}
  categoria="Blog"
  heroAsin={hero?.asin}
  heroAlt={hero?.alt}
>
  <Content />
</ArtigoLayout>
