---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { formatarData } from '@lib/formatters';

const artigos = (await getCollection('blog', ({ data }) => !data.rascunho)).sort(
  (a, b) => b.data.data_publicacao.valueOf() - a.data.data_publicacao.valueOf(),
);
---

<BaseLayout
  titulo="Blog"
  descricao="Novidades sobre Kindle, ebooks em Portugal e o universo da leitura digital."
>
  <div class="tipografia-blog">
  <section class="relative overflow-hidden border-b-4 border-dourado-500 bg-gradient-to-br from-marinho-900 via-oceano-800 to-marinho-800 text-creme-50">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0"
      style="background-image: radial-gradient(ellipse at top right, rgb(212 168 75 / 0.30) 0%, transparent 55%), radial-gradient(ellipse at bottom left, rgb(20 110 180 / 0.35) 0%, transparent 50%);"
    />
    <Container largura="normal" classe="relative z-10 py-14">
      <span class="inline-flex items-center gap-1 rounded-full border border-dourado-400/40 bg-dourado-500/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-dourado-400">
        Blog
      </span>
      <h1 class="mt-3 text-3xl font-bold text-creme-50 md:text-4xl" style="font-family: var(--font-blog); letter-spacing: -0.035em;">
        Notas e atualizações
      </h1>
      <p class="mt-3 max-w-2xl text-oceano-100/90">
        Novidades, atualizações de firmware, promoções e tendências no mundo dos ebooks.
      </p>
    </Container>
  </section>

  <Container largura="normal" classe="py-14">
    {artigos.length === 0 ? (
      <p class="text-marinho-600">Ainda não há artigos publicados.</p>
    ) : (
      <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {artigos.map((a) => (
          <li class="group">
            <a href={`/blog/${a.id}`} class="block">
              {a.data.imagem_hero ? (
                <div class="mb-4 overflow-hidden rounded-xl bg-gradient-to-br from-marinho-50 to-creme-100 transition-transform group-hover:-translate-y-1">
                  <Image
                    src={a.data.imagem_hero}
                    alt={a.data.imagem_hero_alt ?? a.data.titulo}
                    widths={[400, 600, 800]}
                    sizes="(min-width: 1024px) 380px, (min-width: 640px) 50vw, 100vw"
                    class="block aspect-[1200/630] w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              ) : (
                <div class="mb-4 aspect-[1200/630] w-full rounded-xl bg-gradient-to-br from-marinho-100 to-creme-200 transition-transform group-hover:-translate-y-1" />
              )}
              <h2 class="text-lg font-semibold leading-snug text-marinho-900 group-hover:text-marca-600">
                {a.data.titulo}
              </h2>
              <p class="mt-2 text-sm text-marinho-600">{a.data.descricao}</p>
              <p class="mt-2 text-xs text-marinho-400">
                <time datetime={a.data.data_publicacao.toISOString()}>
                  {formatarData(a.data.data_publicacao)}
                </time>
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </Container>
  </div>
</BaseLayout>
