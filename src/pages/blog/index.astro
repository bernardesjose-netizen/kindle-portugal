---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import { getCollection } from 'astro:content';
import { formatarData } from '@lib/formatters';

const artigos = (await getCollection('blog', ({ data }) => !data.rascunho)).sort(
  (a, b) => b.data.data_publicacao.valueOf() - a.data.data_publicacao.valueOf(),
);
---

<BaseLayout
  titulo="Blog"
  descricao="Novidades sobre Kindle, ebooks em Portugal e o universo da leitura digital."
>
  <section class="relative overflow-hidden border-b-4 border-dourado-500 bg-gradient-to-br from-marinho-900 via-oceano-800 to-marinho-800 text-creme-50">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0"
      style="background-image: radial-gradient(ellipse at top right, rgb(212 168 75 / 0.30) 0%, transparent 55%), radial-gradient(ellipse at bottom left, rgb(20 110 180 / 0.35) 0%, transparent 50%);"
    />
    <Container largura="normal" classe="relative z-10 py-14">
      <span class="inline-flex items-center gap-1 rounded-full border border-dourado-400/40 bg-dourado-500/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-dourado-400">
        Blog
      </span>
      <h1 class="mt-3 text-3xl font-bold text-creme-50 md:text-4xl" style="font-family: var(--font-serif);">
        Notas e atualizações
      </h1>
      <p class="mt-3 max-w-2xl text-oceano-100/90">
        Novidades, atualizações de firmware, promoções e tendências no mundo dos ebooks.
      </p>
    </Container>
  </section>

  <Container largura="normal" classe="py-14">
    {artigos.length === 0 ? (
      <p class="text-marinho-600">Ainda não há artigos publicados.</p>
    ) : (
      <ul class="space-y-6">
        {artigos.map((a) => (
          <li class="border-b border-marinho-100 pb-6 last:border-b-0">
            <a href={`/blog/${a.id}`} class="group block">
              <h2 class="text-xl font-semibold text-marinho-900 group-hover:text-marca-600">
                {a.data.titulo}
              </h2>
              <p class="mt-2 text-marinho-600">{a.data.descricao}</p>
              <p class="mt-2 text-xs text-marinho-400">
                <time datetime={a.data.data_publicacao.toISOString()}>
                  {formatarData(a.data.data_publicacao)}
                </time>
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </Container>
</BaseLayout>
