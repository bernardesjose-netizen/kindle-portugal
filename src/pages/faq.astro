---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import { getCollection, render } from 'astro:content';

const perguntas = (await getCollection('faq', ({ data }) => !data.rascunho)).sort(
  (a, b) => a.data.ordem - b.data.ordem,
);

const conteudos = await Promise.all(
  perguntas.map(async (p) => {
    const { Content } = await render(p);
    return { entry: p, Content };
  }),
);

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: perguntas.map((p) => ({
    '@type': 'Question',
    name: p.data.pergunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: p.body ?? '',
    },
  })),
};
---

<BaseLayout
  titulo="Perguntas frequentes"
  descricao="Respostas rápidas às perguntas mais comuns sobre comprar e usar um Kindle em Portugal."
  jsonLd={perguntas.length > 0 ? faqLd : undefined}
>
  <section class="relative overflow-hidden border-b-4 border-dourado-500 bg-gradient-to-br from-marinho-900 via-oceano-800 to-marinho-800 text-creme-50">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0"
      style="background-image: radial-gradient(ellipse at top right, rgb(212 168 75 / 0.30) 0%, transparent 55%), radial-gradient(ellipse at bottom left, rgb(20 110 180 / 0.35) 0%, transparent 50%);"
    />
    <Container largura="normal" classe="relative z-10 py-14">
      <span class="inline-flex items-center gap-1 rounded-full border border-dourado-400/40 bg-dourado-500/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-dourado-400">
        FAQ
      </span>
      <h1 class="mt-3 text-3xl font-bold text-creme-50 md:text-4xl" style="font-family: var(--font-serif);">
        Perguntas frequentes
      </h1>
      <p class="mt-3 max-w-2xl text-oceano-100/90">
        Se não encontrares aqui a tua resposta, diz-nos. Adicionamos à lista.
      </p>
    </Container>
  </section>

  <Container largura="texto" classe="py-14">
    {perguntas.length === 0 ? (
      <p class="text-marinho-600">Ainda não há perguntas publicadas.</p>
    ) : (
      <div class="space-y-6">
        {conteudos.map(({ entry, Content }) => (
          <details class="group rounded-md border border-marinho-100 bg-white p-5 open:shadow-sm">
            <summary class="flex cursor-pointer items-start justify-between gap-3 text-lg font-semibold text-marinho-900">
              <span class="flex-1">{entry.data.pergunta}</span>
              <a
                href={`/faq/${entry.id}`}
                class="shrink-0 self-center rounded-md border border-marinho-100 px-2 py-0.5 text-xs font-normal text-marinho-500 transition hover:border-marca-500 hover:text-marca-700"
                aria-label={`Ver página dedicada: ${entry.data.pergunta}`}
                onclick="event.stopPropagation()"
              >
                Página dedicada →
              </a>
            </summary>
            <div class="prose prose-pt prose-tinta mt-3 max-w-none text-marinho-600">
              <Content />
            </div>
          </details>
        ))}
      </div>
    )}
  </Container>
</BaseLayout>
