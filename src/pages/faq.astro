---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import { getCollection, render } from 'astro:content';

const perguntas = (await getCollection('faq', ({ data }) => !data.rascunho)).sort(
  (a, b) => a.data.ordem - b.data.ordem,
);

const conteudos = await Promise.all(
  perguntas.map(async (p) => {
    const { Content } = await render(p);
    return { entry: p, Content };
  }),
);

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: perguntas.map((p) => ({
    '@type': 'Question',
    name: p.data.pergunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: p.body ?? '',
    },
  })),
};
---

<BaseLayout
  titulo="Perguntas frequentes"
  descricao="Respostas rápidas às perguntas mais comuns sobre comprar e usar um Kindle em Portugal."
  jsonLd={perguntas.length > 0 ? faqLd : undefined}
>
  <Container largura="texto" classe="py-14">
    <header class="mb-10 border-b border-marinho-100 pb-6">
      <h1 class="text-3xl font-bold text-marinho-900 md:text-4xl">Perguntas frequentes</h1>
      <p class="mt-3 text-marinho-600">
        Se não encontrares aqui a tua resposta, diz-nos — adicionamos à lista.
      </p>
    </header>

    {perguntas.length === 0 ? (
      <p class="text-marinho-600">Ainda não há perguntas publicadas.</p>
    ) : (
      <div class="space-y-6">
        {conteudos.map(({ entry, Content }) => (
          <details class="rounded-md border border-marinho-100 bg-white p-5 open:shadow-sm">
            <summary class="cursor-pointer text-lg font-semibold text-marinho-900">
              {entry.data.pergunta}
            </summary>
            <div class="prose prose-pt prose-tinta mt-3 max-w-none text-marinho-600">
              <Content />
            </div>
          </details>
        ))}
      </div>
    )}
  </Container>
</BaseLayout>
