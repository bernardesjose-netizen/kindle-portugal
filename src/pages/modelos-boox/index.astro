---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import BotaoWook from '@components/afiliados/BotaoWook.astro';
import DisclosureBanner from '@components/afiliados/DisclosureBanner.astro';
import ImagemProduto from '@components/afiliados/ImagemProduto.astro';
import { getCollection } from 'astro:content';
import { formatarPreco } from '@lib/formatters';

const modelos = (await getCollection('boox', ({ data }) => !data.rascunho)).sort((a, b) => {
  const pa = a.data.preco_referencia_eur ?? Number.POSITIVE_INFINITY;
  const pb = b.data.preco_referencia_eur ?? Number.POSITIVE_INFINITY;
  return pa - pb;
});

type IconeId = 'cor' | 'livro';

function iconePara(m: (typeof modelos)[number]): { id: IconeId; legenda: string } {
  return m.data.especificacoes.ecra_cor
    ? { id: 'cor', legenda: 'Ecrã a cores' }
    : { id: 'livro', legenda: 'Leitor de ebooks' };
}

// Cada cartão recebe uma cor diferente, para dar vida à grelha.
const paletaCaixa = ['caixa-oceano', 'caixa-salvia', 'caixa-coral'] as const;
const paletaPill = ['pill-oceano', 'pill-salvia', 'pill-coral'] as const;

const destaques = [
  {
    etiqueta: 'Comparação',
    titulo: 'BOOX ou Kindle?',
    texto: 'O que ganhas e o que perdes ao trocar o ecossistema fechado do Kindle por um leitor Android aberto.',
    href: '/guias/leitores-boox-wook-portugal',
    caixa: 'caixa-oceano',
    pill: 'pill-oceano',
  },
  {
    etiqueta: 'Modelos',
    titulo: 'Modelos de Kindle',
    texto: 'A alternativa da Amazon, com envio para Portugal. Fichas de cada modelo, do básico ao Scribe.',
    href: '/modelos',
    caixa: 'caixa-marinho',
    pill: 'pill-marinho',
  },
  {
    etiqueta: 'Ebooks',
    titulo: 'Comprar ebooks em português',
    texto: 'Onde comprar livros em PT para ler em qualquer leitor: WOOK, Kobo, FNAC e Bertrand.',
    href: '/guias/comprar-ebooks-para-kobo-portugal',
    caixa: 'caixa-dourado',
    pill: 'pill-dourado',
  },
] as const;
---

<BaseLayout
  titulo="Leitores BOOX à venda em Portugal pela WOOK (2026)"
  descricao="Fichas dos leitores de ebooks BOOX vendidos em Portugal pela WOOK: BOOX Go 6, Go 7 e Go Color 7. Especificações, preço de referência e para quem é cada um."
>
  <section class="relative overflow-hidden border-b-4 border-marca-500 bg-gradient-to-br from-marinho-900 via-marinho-800 to-oceano-900 text-creme-50">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0"
      style="background-image: radial-gradient(ellipse at top right, rgb(249 126 7 / 0.20) 0%, transparent 55%), radial-gradient(ellipse at bottom left, rgb(20 110 180 / 0.35) 0%, transparent 50%);"
    />
    <Container largura="normal" classe="relative z-10 py-14">
      <span class="inline-flex items-center gap-1 rounded-full border border-marca-400/40 bg-marca-500/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-marca-300">
        BOOX · WOOK · 2026
      </span>
      <h1
        class="mt-3 text-4xl font-bold text-creme-50 md:text-5xl"
        style="font-family: var(--font-serif); letter-spacing: -0.03em;"
      >
        Leitores BOOX em Portugal
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-oceano-100/90">
        Leitores de ebooks com Android e Play Store, vendidos cá pela WOOK e prontos para a
        app wookreader. São a alternativa aberta ao Kindle: leem qualquer formato e instalam
        qualquer aplicação.
      </p>
    </Container>
  </section>

  <div class="border-b border-dourado-400/30 bg-creme-100/70">
    <Container largura="normal" classe="flex flex-col items-center gap-4 py-6 text-center sm:flex-row sm:justify-between sm:text-left">
      <p class="text-marinho-700">
        <strong class="font-semibold text-marinho-900">Oferta WOOK:</strong> na compra de um eReader BOOX, recebes <strong class="font-semibold text-marinho-900">2 eBooks de oferta</strong>.
      </p>
      <BotaoWook url="https://www.wook.pt/pagina/BOOX" tamanho="grande">Ver a gama BOOX na WOOK</BotaoWook>
    </Container>
  </div>

  <Container largura="normal" classe="py-14">
    {modelos.length === 0 ? (
      <p class="text-marinho-600">Ainda não há fichas publicadas. Volta em breve.</p>
    ) : (
      <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {modelos.map((m, i) => {
          const ic = iconePara(m);
          const caixaCor = paletaCaixa[i % paletaCaixa.length];
          const pillCor = paletaPill[i % paletaPill.length];
          return (
            <li class={`caixa ${caixaCor} group relative overflow-hidden`}>
              <a href={`/modelos-boox/${m.id}`} class="block p-6">
                <div
                  class="absolute right-4 top-4 flex h-9 w-9 items-center justify-center rounded-full border border-marinho-100 bg-creme-50 text-marinho-500 shadow-sm transition-colors group-hover:border-marca-300 group-hover:text-marca-600"
                  title={ic.legenda}
                  aria-label={ic.legenda}
                >
                  {ic.id === 'cor' ? (
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <circle cx="13.5" cy="6.5" r="1.5" fill="currentColor" />
                      <circle cx="17.5" cy="10.5" r="1.5" fill="currentColor" />
                      <circle cx="8.5" cy="7.5" r="1.5" fill="currentColor" />
                      <circle cx="6.5" cy="12.5" r="1.5" fill="currentColor" />
                      <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.9 0 1.5-.7 1.5-1.5 0-.4-.2-.8-.5-1.1-.3-.3-.5-.7-.5-1.1 0-.8.7-1.5 1.5-1.5H16c3.3 0 6-2.7 6-6 0-5.5-4.5-9-10-9z" />
                    </svg>
                  ) : (
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
                      <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
                    </svg>
                  )}
                </div>
                {m.data.asin && (
                  <div class="mb-4 flex h-36 items-center justify-center rounded-xl border border-marinho-100/70 bg-gradient-to-br from-white to-creme-100">
                    <ImagemProduto
                      asin={m.data.asin}
                      alt={`${m.data.nome} visto de frente`}
                      tamanho={500}
                      linkar={false}
                      classe="!my-0 max-h-32"
                    />
                  </div>
                )}
                <span class={`pill ${pillCor}`}>{m.data.fabricante} · {m.data.ano_lancamento}</span>
                <h2
                  class="mt-3 pr-10 text-2xl font-bold text-marinho-900 transition-colors group-hover:text-marca-700"
                  style="font-family: var(--font-serif); letter-spacing: -0.02em;"
                >
                  {m.data.nome}
                </h2>
                <p class="mt-3 text-marinho-600">{m.data.descricao_curta}</p>
                {m.data.preco_referencia_eur && (
                  <p class="mt-5 flex items-baseline gap-2 border-t border-marinho-100 pt-4 text-sm">
                    <span class="text-marinho-400">a partir de</span>
                    <strong
                      class="text-lg text-marinho-900"
                      style="font-family: var(--font-serif);"
                    >
                      {formatarPreco(m.data.preco_referencia_eur)}
                    </strong>
                  </p>
                )}
              </a>
            </li>
          );
        })}
      </ul>
    )}

    <p class="mt-8 text-sm text-marinho-500">
      Procuras a alternativa da Amazon? Vê os <a href="/modelos" class="font-semibold text-marca-700 underline decoration-marca-300 underline-offset-2 hover:text-marca-800">modelos de Kindle</a>.
    </p>
  </Container>

  <section class="border-t border-marinho-100 bg-creme-100/50">
    <Container largura="normal" classe="py-14">
      <div class="mb-8 max-w-2xl">
        <span class="pill">Explorar</span>
        <h2
          class="mt-3 text-3xl font-bold text-marinho-900 md:text-4xl"
          style="font-family: var(--font-serif); letter-spacing: -0.025em;"
        >
          Antes de decidir
        </h2>
        <p class="mt-2 text-marinho-600">
          BOOX e Kindle resolvem o mesmo problema de maneiras diferentes. Por onde continuar:
        </p>
      </div>
      <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {destaques.map((d) => (
          <li class={`caixa ${d.caixa} group`}>
            <a href={d.href} class="flex h-full flex-col p-6">
              <span class={`pill ${d.pill}`}>{d.etiqueta}</span>
              <h3
                class="mt-3 text-xl font-bold leading-tight text-marinho-900 transition-colors group-hover:text-marca-700"
                style="font-family: var(--font-serif);"
              >
                {d.titulo}
              </h3>
              <p class="mt-2 flex-1 text-sm text-marinho-600">{d.texto}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-marca-600 group-hover:text-marca-700">
                Abrir
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </Container>
  </section>

  <Container largura="normal" classe="pb-12">
    <DisclosureBanner variante="discreta" redes="WOOK" />
  </Container>
</BaseLayout>
