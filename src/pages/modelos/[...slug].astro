---
import { getCollection, render } from 'astro:content';
import ModeloLayout from '@layouts/ModeloLayout.astro';

export async function getStaticPaths() {
  const modelos = await getCollection('modelos', ({ data }) => !data.rascunho);
  return modelos.map((modelo) => ({
    params: { slug: modelo.id },
    props: { modelo },
  }));
}

const { modelo } = Astro.props;
const { Content } = await render(modelo);
---

<ModeloLayout modelo={modelo}>
  <Content />
</ModeloLayout>
