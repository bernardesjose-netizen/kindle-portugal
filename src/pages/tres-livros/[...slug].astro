---
import { getCollection, render } from 'astro:content';
import ArtigoLayout from '@layouts/ArtigoLayout.astro';
import CardLivro from '@components/CardLivro.astro';
import { urlCapaLivro } from '@lib/capa-livro';

export async function getStaticPaths() {
  const posts = await getCollection('tresLivros', ({ data }) => !data.rascunho);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

// Hero: capa do primeiro livro do post.
// Construímos o URL aqui em vez de usar `heroAsin` (que o ArtigoLayout
// resolve via imagemParaAsin, função que só conhece dispositivos Kindle).
const heroSrc = urlCapaLivro(d.livros[0].asin, 'grande');
const heroAlt = `Capa de ${d.livros[0].titulo}, de ${d.livros[0].autor}`;
---

<ArtigoLayout
  titulo={d.titulo}
  descricao={d.descricao}
  tituloSeo={d.seo?.titulo_seo}
  descricaoSeo={d.seo?.descricao_seo}
  noindex={d.seo?.noindex}
  autor={d.autor}
  dataPublicacao={d.data_publicacao}
  categoria="Três Ebooks"
  imagem={heroSrc}
>
  <Content />

  <section aria-label="Os três livros desta edição" class="not-prose">
    {d.livros.map((livro, i) => (
      <CardLivro
        asin={livro.asin}
        titulo={livro.titulo}
        autor={livro.autor}
        editora={livro.editora}
        ano={livro.ano}
        marketplace={livro.marketplace}
        comentario={livro.comentario}
        urlWook={livro.url_wook}
        numero={i + 1}
      />
    ))}
  </section>
</ArtigoLayout>
