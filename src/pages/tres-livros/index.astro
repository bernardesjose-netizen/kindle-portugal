---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import { getCollection } from 'astro:content';
import { formatarData } from '@lib/formatters';
import { urlCapaLivro } from '@lib/capa-livro';

const posts = (await getCollection('tresLivros', ({ data }) => !data.rascunho)).sort(
  (a, b) => b.data.data_publicacao.valueOf() - a.data.data_publicacao.valueOf(),
);
---

<BaseLayout
  titulo="Três Livros"
  descricao="Sugestões semanais de três livros em português europeu para Kindle. Editoras portuguesas, autores nacionais, traduções PT-PT."
>
  <section class="relative overflow-hidden border-b-4 border-dourado-500 bg-gradient-to-br from-marinho-900 via-oceano-800 to-marinho-800 text-creme-50">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0"
      style="background-image: radial-gradient(ellipse at top right, rgb(212 168 75 / 0.30) 0%, transparent 55%), radial-gradient(ellipse at bottom left, rgb(20 110 180 / 0.35) 0%, transparent 50%);"
    />
    <Container largura="normal" classe="relative z-10 py-14">
      <span class="inline-flex items-center gap-1 rounded-full border border-dourado-400/40 bg-dourado-500/15 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-dourado-400">
        Rubrica semanal
      </span>
      <h1 class="mt-3 text-3xl font-bold text-creme-50 md:text-4xl" style="font-family: var(--font-serif);">
        Três Livros
      </h1>
      <p class="mt-3 max-w-2xl text-oceano-100/90">
        Todas as semanas, três livros em português europeu para o seu Kindle. Editoras portuguesas, autores nacionais, traduções feitas em Portugal. Tudo o que a Kindle Store mistura connosco e que aqui ajudamos a separar.
      </p>
    </Container>
  </section>

  <Container largura="normal" classe="py-14">
    {posts.length === 0 ? (
      <p class="text-marinho-600">Ainda não há posts publicados nesta rubrica.</p>
    ) : (
      <ul class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((p) => {
          const capa1 = urlCapaLivro(p.data.livros[0].asin, 'pequeno');
          const capa2 = urlCapaLivro(p.data.livros[1].asin, 'pequeno');
          const capa3 = urlCapaLivro(p.data.livros[2].asin, 'pequeno');
          return (
            <li class="group">
              <a href={`/tres-livros/${p.id}`} class="block">
                <div class="relative mb-4 grid grid-cols-3 gap-2 rounded-xl bg-gradient-to-br from-marinho-50 to-creme-100 p-4 transition-transform group-hover:-translate-y-1">
                  <img src={capa1} alt={`Capa de ${p.data.livros[0].titulo}`} loading="lazy" decoding="async" class="h-auto w-full object-contain" style="filter: drop-shadow(0 4px 8px rgba(15,26,36,0.18));" referrerpolicy="no-referrer-when-downgrade" onerror="this.style.display='none'" />
                  <img src={capa2} alt={`Capa de ${p.data.livros[1].titulo}`} loading="lazy" decoding="async" class="h-auto w-full object-contain" style="filter: drop-shadow(0 4px 8px rgba(15,26,36,0.18));" referrerpolicy="no-referrer-when-downgrade" onerror="this.style.display='none'" />
                  <img src={capa3} alt={`Capa de ${p.data.livros[2].titulo}`} loading="lazy" decoding="async" class="h-auto w-full object-contain" style="filter: drop-shadow(0 4px 8px rgba(15,26,36,0.18));" referrerpolicy="no-referrer-when-downgrade" onerror="this.style.display='none'" />
                </div>
                <h2 class="text-lg font-semibold leading-snug text-marinho-900 group-hover:text-marca-600">
                  {p.data.titulo}
                </h2>
                <p class="mt-2 text-sm text-marinho-600">{p.data.descricao}</p>
                <p class="mt-2 text-xs text-marinho-400">
                  <time datetime={p.data.data_publicacao.toISOString()}>
                    {formatarData(p.data.data_publicacao)}
                  </time>
                </p>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </Container>
</BaseLayout>
