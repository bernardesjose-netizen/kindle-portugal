---
import BaseLayout from '@layouts/BaseLayout.astro';
import Container from '@components/ui/Container.astro';
import { getCollection } from 'astro:content';
import { formatarData } from '@lib/formatters';

const reviews = (await getCollection('reviews', ({ data }) => !data.rascunho)).sort(
  (a, b) => b.data.data_publicacao.valueOf() - a.data.data_publicacao.valueOf(),
);
---

<BaseLayout
  titulo="Reviews de Kindle, ebooks e acessórios"
  descricao="Reviews honestas de dispositivos, ebooks e acessórios Kindle: com pontos fortes, limitações e um veredito claro."
>
  <Container largura="normal" classe="py-14">
    <header class="mb-10 border-b border-marinho-100 pb-6">
      <h1 class="text-3xl font-bold text-marinho-900 md:text-4xl">Reviews</h1>
      <p class="mt-3 max-w-2xl text-marinho-600">
        Escrevemos apenas sobre o que testámos ou, quando tal não é possível, sinalizamos
        claramente que se trata de análise baseada em pesquisa.
      </p>
    </header>

    {reviews.length === 0 ? (
      <p class="text-marinho-600">Ainda não há reviews publicadas. Volta em breve.</p>
    ) : (
      <ul class="grid gap-6 md:grid-cols-2">
        {reviews.map((r) => (
          <li class="rounded-lg border border-marinho-100 bg-white p-6 transition hover:border-marinho-400">
            <a href={`/reviews/${r.id}`} class="block">
              <p class="text-xs font-semibold uppercase tracking-wider text-marca-600">
                {r.data.tipo}
              </p>
              <h2 class="mt-2 text-xl font-semibold text-marinho-900">{r.data.titulo}</h2>
              <p class="mt-2 text-marinho-600">{r.data.veredito}</p>
              <p class="mt-3 text-xs text-marinho-400">
                {r.data.classificacao.toFixed(1)} / 5 ·{' '}
                <time datetime={r.data.data_publicacao.toISOString()}>
                  {formatarData(r.data.data_publicacao)}
                </time>
              </p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </Container>
</BaseLayout>
