---
import { getCollection, render } from 'astro:content';
import ArtigoLayout from '@layouts/ArtigoLayout.astro';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews', ({ data }) => !data.rascunho);
  return reviews.map((review) => ({
    params: { slug: review.id },
    props: { review },
  }));
}

const { review } = Astro.props;
const { Content } = await render(review);
const d = review.data;
---

<ArtigoLayout
  titulo={d.titulo}
  descricao={d.veredito}
  autor={d.autor}
  dataPublicacao={d.data_publicacao}
  dataRevisao={d.data_revisao}
  categoria={`Review · ${d.tipo}`}
>
  <p class="text-xl text-marinho-800">
    <strong>Classificação:</strong> {d.classificacao.toFixed(1)} / 5
  </p>
  <Content />
</ArtigoLayout>
